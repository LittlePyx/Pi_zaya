{
  "suite_id": "paper_guide_smoke_scinerf2024_v1",
  "title": "Paper Guide Smoke (SCINeRF CVPR 2024 v1)",
  "prefs_patch": {
    "answer_contract_v1": true,
    "answer_depth_auto": true,
    "answer_mode_hint": "reading",
    "answer_output_mode": "reading_guide"
  },
  "generate_body": {
    "top_k": 10,
    "deep_read": true,
    "max_tokens": 5200,
    "temperature": 0.3
