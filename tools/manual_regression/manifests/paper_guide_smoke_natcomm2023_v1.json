{
  "suite_id": "paper_guide_smoke_natcomm2023_v1",
  "title": "Paper Guide Smoke (NatCommun 2023 v1)",
  "prefs_patch": {
    "answer_contract_v1": true,
    "answer_depth_auto": true,
    "answer_mode_hint": "reading",
    "answer_output_mode": "reading_guide"
  },
  "generate_body": {
    "top_k": 8,
    "deep_read": true,
    "max_tokens": 4200,
    "temperature": 0.35
  },
  "default_checks": {
    "structured_markers": {
      "forbid_raw_structured_cites": true,
      "forbid_raw_support_markers": true
    },
    "quality": {
      "minimum_ok_required": true
    }
  },
  "papers": [
    {
      "id": "natcommun_2023_spad_sr",
      "title": "High-resolution single-photon imaging with physics-informed deep learning",
      "source_path": "../../../db/NatCommun-2023-High-resolution single-photon imaging with physics-informed deep learning/NatCommun-2023-High-resolution single-photon imaging with physics-informed deep learning.en.md",
      "source_name": "NatCommun-2023-High-resolution single-photon imaging with physics-informed deep learning.pdf",
      "cases": [
        {
          "id": "NC2023_ABSTRACT_SUMMARY_ZH",
          "title": "Abstract summary with exact anchor (Chinese)",
          "prompt_family": "abstract",
          "tags": ["abstract", "zh", "general"],
          "prompt": "请用中文总结这篇文章的摘要内容（不少于 150 字），然后给出 1 句可定位跳转的原文锚点来支持你的总结。",
          "checks": {
            "answer": {
              "contains_any": [
                "single-photon",
                "SPAD",
                "super-resolution",
                "transformer"
              ]
            },
            "locate": {
              "required": true,
              "exact": true,
              "anchor_contains_any": [
                "High-resolution single-photon imaging remains a big challenge",
                "introduce deep learning into SPAD"
              ]
            }
          }
        },
        {
          "id": "NC2023_CITATION_TRANSFORMER_FRAMEWORK",
          "title": "Transformer framework citations",
          "prompt_family": "citation_lookup",
          "tags": ["citation_lookup", "general"],
          "prompt": "Which references do the authors cite for the transformer framework, and where is that stated exactly? Give the exact supporting sentence.",
          "checks": {
            "answer": {
              "contains_any": ["transformer framework"]
            },
            "citation": {
              "required": true,
              "expected_ref_nums": [33, 34],
              "allow_only_expected": true
            },
            "locate": {
              "required": true,
              "exact": true,
              "anchor_contains_any": ["transformer framework"]
            }
          }
        },
        {
          "id": "NC2023_CITATION_PASCAL_VOC",
          "title": "PASCAL VOC dataset citations",
          "prompt_family": "citation_lookup",
          "tags": ["citation_lookup", "general"],
          "prompt": "The authors mention using off-the-shelf public high-resolution images from PASCAL VOC2007/VOC2012 to synthesize training data. Which references correspond to those datasets, and where is that stated exactly?",
          "checks": {
            "answer": {
              "contains_any": ["PASCAL", "VOC2007", "VOC2012"]
            },
            "citation": {
              "required": true,
              "expected_ref_nums": [31, 32],
              "allow_only_expected": true
            },
            "locate": {
              "required": true,
              "exact": true,
              "anchor_contains_any": ["PASCAL", "VOC2007", "VOC2012"]
            }
          }
        },
        {
          "id": "NC2023_METHOD_NETWORK_TRAINING",
          "title": "Network training exact details",
          "prompt_family": "method",
          "tags": ["method_exact_support", "general"],
          "prompt": "In the Network training section, what framework (PyTorch), optimizer, initial learning rate, and batch size did they use? Point me to the exact supporting sentence(s) and make sure the jump target is correct.",
          "checks": {
            "answer": {
              "contains_all": ["Pytorch", "Adam", "0.0003", "batch size", "24"],
              "not_contains_any": ["not stated", "does **not** contain", "does not contain", "cannot be determined"]
            },
            "locate": {
              "required": true,
              "exact": true,
              "heading_includes_any": ["Network training"],
              "anchor_contains_any": ["Pytorch", "Adam", "learning rate", "batch size"]
            }
          }
        },
        {
          "id": "NC2023_FIGURE6_PANEL_B_CLAUSE",
          "title": "Figure 6 panel (b) caption clause jump",
          "prompt_family": "figure_walkthrough",
          "tags": ["figure_panel_locate", "general"],
          "prompt": "For Figure 6 panel (b), what exactly does that panel show? Point me to the exact supporting caption clause.",
          "checks": {
            "answer": {
              "contains_any": ["Figure 6", "panel b", "U-net", "transformer"]
            },
            "figure_panel": {
              "required": true,
              "panel_letters": ["b"],
              "heading_includes_any": ["Workflow and structure", "Figure 6"],
              "anchor_contains_any": ["enhancement comparison", "U-net"],
              "claim_types": ["figure_panel"]
            },
            "locate": {
              "required": true,
              "exact": true,
              "heading_includes_any": ["Workflow and structure", "Figure 6"],
              "anchor_contains_any": ["enhancement comparison", "U-net"],
              "claim_types": ["figure_panel"]
            },
            "jump": {
              "required": true
            }
          }
        }
      ]
    }
  ]
}
